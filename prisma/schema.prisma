generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

enum Role {
  SUPERADMIN
  ADMIN
  DOCTOR
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
}

model Organization {
  id                String   @id @default(uuid())
  name              String
  slug              String   @unique // subdomain
  stripe_connect_id String?
  settings_json     Json?    @default("{}")
  ai_usage_count    Int      @default(0)
  is_active         Boolean  @default(true)
  
  users             User[]
  patients          Patient[]
  appointments      Appointment[]
  whatsappConversations WhatsappConversation[]
  whatsappProcessedMessages WhatsappProcessedMessage[]
  whatsappMessageStatuses WhatsappMessageStatus[]
  settings          OrganizationSettings?
  auditLogs         AuditLog[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model OrganizationSettings {
  id                    String       @id @default(uuid())
  organization_id       String       @unique
  organization          Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  google_calendar_id    String?
  stripe_account_id     String?
  whatsapp_access_token String?
  whatsapp_phone_id     String?
  custom_metadata       Json?        @default("{}")

  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
}

model User {
  id              String       @id @default(uuid())
  email           String       @unique
  name            String?
  image           String?
  emailVerified   DateTime?
  role            Role         @default(DOCTOR)
  organization_id String
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  
  doctorAppointments Appointment[] @relation("DoctorAppointments")
  accounts         Account[]
  sessions         Session[]
  auditLogs        AuditLog[]

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  oauth_token_secret String?
  oauth_token       String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Patient {
  id                   String       @id @default(uuid())
  organization_id      String
  organization         Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  full_name            String
  phone_number         String?
  curp                 String?      // or ID
  birth_date           DateTime?
  medical_history_json Json?        @default("{}")

  appointments         Appointment[]

  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@index([organization_id, full_name])
  @@index([organization_id, phone_number])
}

model WhatsappConversation {
  id              String       @id @default(uuid())
  organization_id String
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  patient_phone   String
  last_slots      Json?        @default("[]")
  last_intent     String?
  status          String       @default("ACTIVE")
  current_state   String       @default("IDLE")
  last_message_at DateTime     @default(now())
  opt_in_at       DateTime?
  opted_out_at    DateTime?
  handoff_requested_at DateTime?
  last_handoff_reason  String?

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([organization_id, patient_phone])
  @@index([organization_id, updatedAt])
}

model WhatsappProcessedMessage {
  id                  String        @id @default(uuid())
  provider_message_id String        @unique
  organization_id     String?
  organization        Organization? @relation(fields: [organization_id], references: [id], onDelete: SetNull)
  patient_phone       String?
  action              String?

  createdAt           DateTime      @default(now())

  @@index([organization_id, createdAt])
}

model WhatsappMessageStatus {
  id                  String        @id @default(uuid())
  provider_message_id String
  organization_id     String?
  organization        Organization? @relation(fields: [organization_id], references: [id], onDelete: SetNull)
  recipient_id        String?
  status              String
  provider_timestamp  DateTime?
  raw_payload         Json?         @default("{}")

  createdAt           DateTime      @default(now())

  @@unique([provider_message_id, status])
  @@index([organization_id, createdAt])
}

model Appointment {
  id              String       @id @default(uuid())
  organization_id String
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  
  doctor_id       String
  doctor          User         @relation("DoctorAppointments", fields: [doctor_id], references: [id])
  
  patient_id      String
  patient         Patient      @relation(fields: [patient_id], references: [id], onDelete: Cascade)
  
  start_time      DateTime
  status          AppointmentStatus @default(SCHEDULED)
  payment_status  PaymentStatus     @default(PENDING)
  google_event_id String?
  reservation_expires_at DateTime?
  cancellation_reason String?

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([organization_id, start_time])
}

model Medication {
  id          String   @id @default(uuid())
  name        String   @unique
  common_dose String
  warnings    Json?    @default("[]")
  legal_notes String?
  is_active   Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id             String        @id @default(uuid())
  userId         String?
  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  action         String
  resource       String
  payload        Json?         @default("{}")
  ip             String?

  createdAt      DateTime      @default(now())

  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
}
